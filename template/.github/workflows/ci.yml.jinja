name: CI

on:
  push:
    branches: [main]
  pull_request:

jobs:
  test:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
      - uses: actions/setup-python@v5
        with:
          python-version: "{{ python_version }}"
      - run: pip install -e ".[dev]"
      - run: pytest --no-header -rN || test $? -eq 5
